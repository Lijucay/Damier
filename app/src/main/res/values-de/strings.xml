    <string-array name="streak_m_ns">
        <item>Tipp drauf. Einmal reicht.</item>
        <item>Von alleine fängt das nicht an.</item>
        <item>Der Knopf ist direkt da.</item>
        <item>Null ist peinlich.</item>
        <item>Einmal drücken. Bitte.</item>
        <item>Fang an. Bitte. Einfach anfangen.</item>
        <item>Na, das ist unangenehm.</item>
        <item>Jederzeit gerne.</item>
        <item>Na los.</item>
        <item>Kein Stress, aber fang an.</item>
        <item>Mutig, so zu warten.</item>
    </string-array>

    <string-array name="streak_m_s">
        <item>Du hast noch nicht aufgehört. Noch nicht.</item>
        <item>Die Streak lebt. Vorerst.</item>
        <item>Jetzt bloß nicht aufhören!</item>
        <item>Wer bist du nochmal?</item>
        <item>Streak intakt. Gern geschehen.</item>
        <item>Läuft. So halbwegs.</item>
        <item>Jetzt nicht versauen!</item>
        <item>Streak-Status: Überraschend lebendig.</item>
        <item>Noch dabei? Respekt.</item>
        <item>Nicht schlecht. Weiter so.</item>
        <item>Die Streak ist fragil. Vorsicht.</item>
        <item>Du bist auf Kurs. Mini-Kurs.</item>
    </string-array>

    <string-array name="streak_m_m">
        <item>Noch hier? Ehrlich überrascht.</item>
        <item>Die Streak wird langsam arrogant.</item>
        <item>Eine Woche. Ruin es nicht.</item>
        <item>Okay, du bist konsistent. Ugh.</item>
        <item>Das hat die App nicht erwartet.</item>
        <item>Die Streak ist echt. Behandle sie gut.</item>
        <item>Du ziehst das durch. Irgendwie.</item>
        <item>Fast eine Gewohnheit. Fast.</item>
        <item>Du läufst verdächtig gut.</item>
        <item>Aufhören wird schwerer. Gut so.</item>
        <item>Eine Woche durch. Keine Ausreden.</item>
        <item>Gewohnheit lädt… Bitte warten</item>
        <item>Fast beeindruckend. Fast.</item>
        <item>Du steckst zu tief drin zum Aufhören.</item>
        <item>Jetzt aufzuhören wäre kriminell.</item>
    </string-array>

    <string-array name="streak_m_l">
        <item>Die Gewohnheit lebt.</item>
        <item>Das bist du jetzt.</item>
        <item>Kein Zurück mehr. Sorry.</item>
        <item>Aufhören geht nicht. Wär zu komisch.</item>
        <item>Die Gewohnheit beobachtet dich beim Schlafen.</item>
        <item>Widerstand ist zwecklos.</item>
        <item>Du bist jetzt so eine Art große Sache.</item>
        <item>Die Streak ist permanent. Quasi.</item>
    </string-array>
